generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ScheduleItem
// ---------------------------------------------------------------------------
model ScheduleItem {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(200)
  description String?   @db.Text
  location    String?   @db.VarChar(200)
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([startsAt])
}

// ---------------------------------------------------------------------------
// NewsPost
// ---------------------------------------------------------------------------
enum NewsPostType {
  NEWS
  ANNOUNCEMENT
}

model NewsPost {
  id        String       @id @default(cuid())
  headline  String       @db.VarChar(300)
  body      String       @db.Text
  imageUrl  String?      @db.VarChar(2048)
  type      NewsPostType @default(NEWS)
  pinned    Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([pinned, createdAt])
}

// ---------------------------------------------------------------------------
// ResourceLink
// ---------------------------------------------------------------------------
model ResourceLink {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(200)
  url         String   @db.VarChar(2048)
  description String?  @db.Text
  category    String   @db.VarChar(50)
  createdAt   DateTime @default(now())

  @@index([category])
}

// ---------------------------------------------------------------------------
// BlogPost
// ---------------------------------------------------------------------------
model BlogPost {
  id            String   @id @default(cuid())
  title         String   @db.VarChar(300)
  body          String   @db.Text
  excerpt       String?  @db.VarChar(500)
  coverImageUrl String?  @db.VarChar(2048)
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published, createdAt])
}

// ---------------------------------------------------------------------------
// HelpRequest
// ---------------------------------------------------------------------------
enum HelpRequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

model HelpRequest {
  id        String            @id @default(cuid())
  teamName  String            @db.VarChar(200)
  status    HelpRequestStatus @default(PENDING)
  claimedBy String?           @db.VarChar(200)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Project
// ---------------------------------------------------------------------------
model Project {
  id            String       @id @default(cuid())
  teamName      String       @db.VarChar(200)
  projectName   String       @db.VarChar(200)
  description   String?      @db.Text
  iframeUrl     String       @db.VarChar(2048)
  createdAt     DateTime     @default(now())
  teamAccountId String?      @unique
  teamAccount   TeamAccount? @relation(fields: [teamAccountId], references: [id], onDelete: SetNull)

  @@unique([teamName])
}

enum TeamRole {
  TEAM
  MENTOR
  ADMIN
}

// ---------------------------------------------------------------------------
// TeamAccount  (one per participating team — created by organisers)
// ---------------------------------------------------------------------------
model TeamAccount {
  id           String        @id @default(cuid())
  username     String        @unique @db.VarChar(50)
  passwordHash String
  displayName  String?       @db.VarChar(100)
  role         TeamRole      @default(TEAM)
  createdAt    DateTime      @default(now())
  sessions     TeamSession[]
  project      Project?
  posts        Post[]
  comments     Comment[]
  reactions    Reaction[]
}

// ---------------------------------------------------------------------------
// Post  (social wall post)
// ---------------------------------------------------------------------------
model Post {
  id            String      @id @default(cuid())
  content       String      @db.Text
  imageUrl      String?     @db.VarChar(2048)
  teamAccountId String
  teamAccount   TeamAccount @relation(fields: [teamAccountId], references: [id], onDelete: Cascade)
  comments      Comment[]
  reactions     Reaction[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Comment
// ---------------------------------------------------------------------------
model Comment {
  id            String      @id @default(cuid())
  body          String      @db.Text
  postId        String
  post          Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  teamAccountId String
  teamAccount   TeamAccount @relation(fields: [teamAccountId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([postId, createdAt])
}

// ---------------------------------------------------------------------------
// Reaction  (emoji toggle — one of each emoji per account per post)
// ---------------------------------------------------------------------------
model Reaction {
  id            String      @id @default(cuid())
  emoji         String      @db.VarChar(10)
  postId        String
  post          Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  teamAccountId String
  teamAccount   TeamAccount @relation(fields: [teamAccountId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([postId, teamAccountId, emoji])
  @@index([postId])
}

// ---------------------------------------------------------------------------
// TeamSession  (httpOnly cookie token)
// ---------------------------------------------------------------------------
model TeamSession {
  id        String      @id @default(cuid())
  token     String      @unique @db.VarChar(64)
  accountId String
  account   TeamAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// EventConfig (singleton — always id = "1")
// ---------------------------------------------------------------------------
model EventConfig {
  id                 String   @id @default("1")
  eventName          String   @db.VarChar(200)
  submissionDeadline DateTime
  wifiSsid           String?  @db.VarChar(200)
  wifiPassword       String?  @db.VarChar(200)
  discordUrl         String?  @db.VarChar(2048)
  importantLinks     Json     @default("[]")
  location           String?  @db.VarChar(400)
  locationUrl        String?  @db.VarChar(2048)
  contactEmail       String?  @db.VarChar(200)
  contactPhone       String?  @db.VarChar(50)
  sponsors           Json     @default("[]")
  submitCode         String?  @db.VarChar(50)
  updatedAt          DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Music Voting
// ---------------------------------------------------------------------------

enum BattleStatus {
  PENDING
  ACTIVE
  DONE
}

model MusicTrack {
  id           String   @id @default(cuid())
  spotifyId    String   @unique @db.VarChar(64)
  title        String   @db.VarChar(300)
  artist       String   @db.VarChar(300)
  albumArt     String?  @db.VarChar(2048)
  previewUrl   String?  @db.VarChar(2048)
  nominatedBy  String?  @db.VarChar(100)
  createdAt    DateTime @default(now())

  battlesAsA MusicBattle[] @relation("TrackA")
  battlesAsB MusicBattle[] @relation("TrackB")
  battlesWon MusicBattle[] @relation("Winner")
}

model MusicBattle {
  id        String        @id @default(cuid())
  status    BattleStatus  @default(PENDING)
  trackAId  String
  trackBId  String
  winnerId  String?
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime      @default(now())

  trackA MusicTrack  @relation("TrackA", fields: [trackAId], references: [id])
  trackB MusicTrack  @relation("TrackB", fields: [trackBId], references: [id])
  winner MusicTrack? @relation("Winner", fields: [winnerId], references: [id])
  votes  BattleVote[]

  @@index([status])
}

model BattleVote {
  id            String   @id @default(cuid())
  battleId      String
  teamAccountId String
  pickedId      String
  createdAt     DateTime @default(now())

  battle MusicBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, teamAccountId])
  @@index([battleId])
}

model FallbackTrack {
  id         String   @id @default(cuid())
  spotifyId  String   @unique @db.VarChar(64)
  title      String   @db.VarChar(300)
  artist     String   @db.VarChar(300)
  albumArt   String?  @db.VarChar(2048)
  previewUrl String   @db.VarChar(2048)
  createdAt  DateTime @default(now())
}
